<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record model="waste.category" id="waste_category_01">
            <field name="name">Plastik</field>
            <field name="description">
                Sampah berbahan dasar plastik, bisa didaur ulang menjadi bijih plastik atau kerajinan.
            </field>
        </record>

        <record model="waste.category" id="waste_category_02">
            <field name="name">Kertas</field>
            <field name="description">
                Sampah berbahan kertas yang masih bisa diolah kembali, seperti kardus, koran, dan dokumen.
            </field>
        </record>

        <record model="waste.category" id="waste_category_03">
            <field name="name">Logam</field>
            <field name="description">
                Limbah berbahan logam yang bernilai tinggi untuk peleburan, seperti besi, aluminium, dan tembaga.
            </field>
        </record>

        <record model="waste.category" id="waste_category_04">
            <field name="name">Kaca</field>
            <field name="description">
                Limbah kaca atau botol yang dapat diolah kembali, seperti botol kaca dan toples bekas.
            </field>
        </record>

        <record model="waste.category" id="waste_category_05">
            <field name="name">Organik</field>
            <field name="description">
                Sampah mudah terurai yang bisa diolah menjadi kompos, seperti sisa makanan dan daun kering.
            </field>
        </record>

        <record model="waste.category" id="waste_category_06">
            <field name="name">Tekstil</field>
            <field name="description">
                Limbah kain dan pakaian bekas yang bisa didaur ulang atau disumbangkan.
            </field>
        </record>
    </data>
</odoo>