<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">
    <record id="user_ecocycle_api" model="res.users" context="{'no_reset_password': True, 'no_reset_password': True}">
      <field name="name">EcoCycle API</field>
      <field name="login">ecocycle_api</field>
      <field name="groups_id" eval="[(6, 0, [])]"/>
    </record>

    <record id="group_ecocycle_api" model="res.groups">
      <field name="name">EcoCycle API</field>
      <field name="users" eval="[(4, ref('user_ecocycle_api'))]"/>
      <field name="implied_ids" eval="[(4, ref('fastapi.group_fastapi_endpoint_runner'))]"/>
    </record>
  </data>
</odoo>
