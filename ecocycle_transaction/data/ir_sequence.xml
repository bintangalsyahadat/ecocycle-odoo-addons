<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_purchase_transaction" model="ir.sequence">
            <field name="name">Purchase Transaction Sequence</field>
            <field name="code">purchase.transaction</field>
            <field name="prefix">PTX%(year)s</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="implementation">standard</field>
        </record>

        <record id="seq_sale_transaction" model="ir.sequence">
            <field name="name">Sale Transaction Sequence</field>
            <field name="code">sale.transaction</field>
            <field name="prefix">STX%(year)s</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="implementation">standard</field>
        </record>
    </data>
</odoo>