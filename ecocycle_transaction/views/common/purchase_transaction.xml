<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="list_purchase_transaction" model="ir.ui.view">
            <field name="name">Purchase_transaction List View</field>
            <field name="model">purchase.transaction</field>
            <field name="arch" type="xml">
                <list string="Purchase_transaction">
                    <field name="name" string="Name"/>
                    <field name="date" string="Date"/>
                    <field name="partner_id" string="Partner"/>
                    <field name="estimate_total_amount" string="Estimate Total Amount"/>
                    <field name="total_amount" string="Total Amount"/>
                    <field name="operating_unit_id" string="Operating Unit"/>
                    <field name="state" string="Status"/>
                </list>
            </field>
        </record>

        <record id="form_purchase_transaction" model="ir.ui.view">
            <field name="name">Purchase_transaction Form View</field>
            <field name="model">purchase.transaction</field>
            <field name="arch" type="xml">
                <form string="Purchase_transaction">
                    <header>
                        <button name="action_confirm" string="Confirm" class="oe_highlight" type="object" invisible="state != 'draft'"/>
                        <button name="action_approve" string="Approve" class="oe_highlight" type="object" invisible="state != 'waiting_approval'"/>
                        <button name="action_reject" string="Reject" type="object" invisible="state != 'waiting_approval'"/>
                        <button name="action_process" string="Process" class="oe_highlight" type="object" invisible="state != 'waiting_process'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,waiting_approval,waiting_process,purchased"/>
                    </header>
                    <sheet>
                        <!-- <div class="oe_button_box" name="button_box">
                            <button name="action_open_pickings" type="object" class="oe_stat_button" icon="fa-truck" invisible="not picking_ids">
                                <div>Pickings</div>
                            </button>
                        </div> -->

                        <div class="oe_title" invisible="state == 'draft' and name == False">
                            <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="partner_id" readonly="state != 'draft'"/>
                                <field name="operating_unit_id" readonly="state != 'draft'"/>
                                <field name="delivery_method_id" readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <field name="date" widget="date" readonly="state != 'draft'"/>
                                <field name="scheduled_date" invisible="not delivery_method_id or is_self_service or state == 'draft'" 
                                    required="not is_self_service and state == 'waiting_approval'" 
                                    readonly="state != 'waiting_approval'"/>
                                <field name="delivery_address_id" invisible="not delivery_method_id or is_self_service" 
                                    readonly="state != 'draft'"/>
                                <field name="note" readonly="state != 'draft'"/>
                                <field name="is_self_service" invisible="1"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Lines">
                                <field name="line_ids" readonly="state != 'draft'">
                                    <list editable="bottom">
                                        <field name="waste_category_id"/>
                                        <field name="quantity" string="Quantity"/>
                                        <field name="unit_price" string="Unit Price"/>
                                        <field name="estimate_total_price" string="Estimate Total Price"/>
                                        <field name="valid_qty" column_invisible="parent.state in ['draft', 'waiting_approval']"/>
                                        <field name="total_price" column_invisible="parent.state in ['draft', 'waiting_approval']" string="Total Price"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>