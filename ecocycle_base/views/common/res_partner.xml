<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="0">
    <record id="list_res_partner" model="ir.ui.view">
      <field name="name">Res_partner List View</field>
      <field name="model">res.partner</field>
      <field name="arch" type="xml">
        <list string="Res_partner" create="0" edit="0" delete="0">
          <field name="name"/>
          <field name="email"/>
        </list>
      </field>
    </record>

    <record id="form_res_partner" model="ir.ui.view">
      <field name="name">Res_partner Form View</field>
      <field name="model">res.partner</field>
      <field name="arch" type="xml">
        <form string="Res_partner" create="0" edit="1" delete="0">
          <sheet>
            <div class="oe_button_box" name="button_box">
              <button name="action_open_planner" type="object" class="oe_stat_button" icon="fa-calendar">
                <div>EcoPlanners</div>
              </button>
            </div>

            <div class="oe_title">
              <label for="name" class="oe_edit_only"/>
              <h1>
                <field name="name"/>
              </h1>
            </div>
            <group>
              <group>
                <field name="email"/>
                <field name="phone"/>
              </group>
              <group>
                <field name="current_ou_id"/>
                <field name="firebase_uuid" readonly="1" groups="base.group_no_one"/>
              </group>
            </group>
          </sheet>
        </form>
      </field>
    </record>
  </data>
</odoo>