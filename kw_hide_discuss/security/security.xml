<odoo>
    <record id="module_category_kw_hide_discuss" model="ir.module.category">
        <field name="name">Discuss access</field>
        <field name="sequence">30</field>
    </record>
    <record id="group_kw_hide_discuss_user" model="res.groups">
        <field name="name">Discuss user</field>
        <field name="category_id"
            ref="kw_hide_discuss.module_category_kw_hide_discuss" />
    </record>

    <record id="group_access_apps_menu" model="res.groups">
        <field name="name">Access Apps Menu</field>
        <field name="category_id" ref="" />
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]" />
        <field name="users" eval="[(4, ref('base.user_admin'))]" />
    </record>
</odoo>